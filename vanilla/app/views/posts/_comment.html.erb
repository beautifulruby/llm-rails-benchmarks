<div class="<%= 'ml-8' if depth > 0 %> border-l-2 border-gray-200 pl-4">
  <div class="bg-gray-50 rounded-lg p-4">
    <div class="flex justify-between items-start">
      <div class="text-sm text-gray-500">
        <strong><%= comment.user.name %></strong> &middot; <%= time_ago_in_words(comment.created_at) %> ago
      </div>
      <%= link_to "Delete", [post, comment], method: :delete, data: { confirm: "Delete this comment?" },
          class: "text-red-500 text-sm hover:underline" %>
    </div>
    <p class="mt-2 text-gray-700"><%= comment.body %></p>

    <% if depth < 3 %>
      <details class="mt-3">
        <summary class="text-blue-600 text-sm cursor-pointer hover:underline">Reply</summary>
        <div class="mt-2">
          <%= render "comment_form", post: post, comment: Comment.new, parent_id: comment.id %>
        </div>
      </details>
    <% end %>
  </div>

  <% if comment.replies.any? %>
    <div class="mt-4 space-y-4">
      <% comment.replies.each do |reply| %>
        <%= render "comment", comment: reply, post: post, depth: depth + 1 %>
      <% end %>
    </div>
  <% end %>
</div>
