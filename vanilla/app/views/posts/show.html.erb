<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "&larr; Back to posts".html_safe, posts_path, class: "text-blue-600 hover:underline" %>
  </div>

  <article class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-4"><%= @post.title %></h1>
    <div class="text-sm text-gray-500 mb-6">
      By <%= @post.user.name %> &middot; <%= time_ago_in_words(@post.created_at) %> ago
    </div>
    <div class="prose prose-gray max-w-none">
      <%= simple_format(@post.body) %>
    </div>
  </article>

  <div class="flex gap-4 mb-8">
    <%= link_to "Edit", edit_post_path(@post), class: "text-blue-600 hover:underline" %>
    <%= link_to "Delete", @post, method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:underline" %>
  </div>

  <hr class="my-8">

  <section>
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Comments (<%= @post.comments.count %>)</h2>

    <%= render "comment_form", post: @post, comment: @comment %>

    <div class="mt-8 space-y-6">
      <% @comments.each do |comment| %>
        <%= render "comment", comment: comment, post: @post, depth: 0 %>
      <% end %>
    </div>
  </section>
</div>
